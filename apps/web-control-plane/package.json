{
  "name": "@soulism/web-control-plane",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "docs:manifest": "node scripts/docs-manifest.mjs",
    "build": "pnpm run docs:manifest && next build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "pnpm -C ../.. exec vitest run --project unit apps/web-control-plane/test/client.spec.ts apps/web-control-plane/test/observability.spec.ts apps/web-control-plane/test/proxy-route.spec.ts apps/web-control-plane/test/session-auth.spec.ts apps/web-control-plane/test/session-route.spec.ts apps/web-control-plane/test/health-readiness.spec.ts",
    "smoke": "pnpm run test && pnpm run build",
    "dev": "pnpm run docs:manifest && next dev",
    "start": "next start",
    "preview": "npx --yes vercel@49.0.0 dev",
    "deploy": "npx --yes vercel@49.0.0 deploy --prod -y"
  },
  "dependencies": {
    "next": "^16.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.8.3"
  }
}