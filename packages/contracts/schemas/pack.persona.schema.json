{
  "$id": "https://cognitive.ai/schema/pack.persona.schema.json",
  "title": "PackPersonaManifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "risk_class",
    "allowed_tools"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "riskClass": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "extends": {
      "type": ["array", "string"],
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "style": {
      "type": "object",
      "properties": {
        "tone": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "systemPrompt": {
      "type": "string"
    },
    "userPromptTemplate": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
