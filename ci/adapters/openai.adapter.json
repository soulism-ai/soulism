{
  "id": "openai-apps",
  "status": "active",
  "runtime": "http",
  "integrationBoundary": "mcp-gateway",
  "artifacts": [
    "marketplace/openai/app.json",
    "apps/openai-app-quickstart/src/index.ts"
  ],
  "channels": ["chatgpt-apps", "openai-apps-marketplace"],
  "contract": {
    "schemaVersion": "1.0.0",
    "transport": {
      "protocol": "http",
      "auth": "oauth2",
      "requestEnvelope": "mcp-http-request-v1",
      "responseEnvelope": "mcp-http-response-v1",
      "traceHeader": "x-trace-id"
    },
    "policyEnforcement": true,
    "auditEmission": true,
    "riskClasses": ["low", "medium", "high"],
    "capabilities": ["persona-render", "policy-check", "tool-mediation", "marketplace-distribution"],
    "compatibility": {
      "minCliVersion": "0.1.0",
      "minSdkVersion": "0.1.0",
      "mcpSchemaVersion": "1.0.0"
    }
  }
}
