{
  "$id": "https://cognitive.ai/schema/audit-evidence.schema.json",
  "title": "AuditEvidenceEnvelope",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "recordType", "source", "payload", "payloadDigest", "digest"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordType": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": ["service", "mode", "releaseId"],
      "properties": {
        "service": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "releaseId": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "runId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "payloadDigest": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "previousDigest": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
