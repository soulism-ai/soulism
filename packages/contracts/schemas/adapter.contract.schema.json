{
  "$id": "https://cognitive.ai/schema/adapter.contract.schema.json",
  "title": "AdapterContractDescriptor",
  "type": "object",
  "required": [
    "id",
    "status",
    "runtime",
    "integrationBoundary",
    "artifacts",
    "channels",
    "contract"
  ],
  "properties": {
    "id": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "planned"] },
    "runtime": { "type": "string" },
    "integrationBoundary": { "type": "string" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "contract": {
      "type": "object",
      "required": [
        "schemaVersion",
        "transport",
        "policyEnforcement",
        "auditEmission",
        "riskClasses",
        "capabilities",
        "compatibility"
      ],
      "properties": {
        "schemaVersion": { "type": "string" },
        "transport": {
          "type": "object",
          "required": ["protocol", "auth", "requestEnvelope", "responseEnvelope", "traceHeader"],
          "properties": {
            "protocol": { "type": "string", "enum": ["http", "stdio"] },
            "auth": { "type": "string", "enum": ["none", "api-key", "oauth2", "mcp-session"] },
            "requestEnvelope": { "type": "string" },
            "responseEnvelope": { "type": "string" },
            "traceHeader": { "type": "string" }
          }
        },
        "policyEnforcement": { "type": "boolean" },
        "auditEmission": { "type": "boolean" },
        "riskClasses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "compatibility": {
          "type": "object",
          "required": ["minCliVersion", "minSdkVersion", "mcpSchemaVersion"],
          "properties": {
            "minCliVersion": { "type": "string" },
            "minSdkVersion": { "type": "string" },
            "mcpSchemaVersion": { "type": "string" }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
