{
  "$id": "https://cognitive.ai/schema/marketplace.hf.schema.json",
  "title": "HfSpaceMarketplaceDescriptor",
  "type": "object",
  "required": ["name", "description", "publisher", "version", "endpoints", "provenance"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "endpoints": {
      "type": "object",
      "required": ["space", "api"],
      "properties": {
        "space": { "type": "string" },
        "api": { "type": "string" },
        "health": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assets": {
      "type": "object",
      "properties": {
        "icon": { "type": "string" },
        "banner": { "type": "string" },
        "screenshots": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "runtime": { "type": "string", "minLength": 1 },
        "schemaVersion": { "type": "string", "minLength": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["publisher", "digest", "signature", "createdAt"],
      "properties": {
        "publisher": { "type": "string" },
        "digest": { "type": "string", "pattern": "^sha256:[A-Fa-f0-9]{64}$" },
        "signature": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "additionalProperties": true
}
