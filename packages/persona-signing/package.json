{
  "name": "@soulism/persona-signing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "pnpm -C ../.. exec vitest run --project unit packages/persona-signing/test/signing.spec.ts",
    "smoke": "pnpm run test"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.922.0",
    "@soulism/persona-schema": "workspace:*",
    "@soulism/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^2.1.0"
  }
}